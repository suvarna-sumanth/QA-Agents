rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PROTOTYPE RULES
     * Allows all authenticated users full access to all documents.
     * Explicitly matches common collection groups to ensure no blocks during prototype development.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow collection group queries for core entities
    match /{path=**}/qa_runs/{runId} {
      allow read, write: if request.auth != null;
    }
    match /{path=**}/articles/{articleId} {
      allow read, write: if request.auth != null;
    }
    match /{path=**}/publisher_sites/{siteId} {
      allow read, write: if request.auth != null;
    }
  }
}