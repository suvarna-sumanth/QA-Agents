rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PROTOTYPE RULES
     * Allows all authenticated users full access to all documents and collection groups.
     * This is the most permissive setup for development and testing.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}