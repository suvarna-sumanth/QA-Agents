rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PROTOTYPE RULES
     * Allows all authenticated users full access to all documents.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * COLLECTION GROUP RULES
     * Explicitly allow collectionGroup queries for the 'qa_runs' collection.
     * This is required for queries that search across all publisher sites.
     */
    match /{path=**}/qa_runs/{runId} {
      allow read: if request.auth != null;
    }
    
    match /{path=**}/player_test_results/{resultId} {
      allow read: if request.auth != null;
    }
    
    match /{path=**}/audio_test_results/{resultId} {
      allow read: if request.auth != null;
    }
    
    match /{path=**}/bug_reports/{reportId} {
      allow read: if request.auth != null;
    }
  }
}