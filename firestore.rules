rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PROTOTYPE RULES
     * Allows all authenticated users full access to simplify the development loop.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * COLLECTION GROUP RULES
     * Specifically allow collection group queries for 'qa_runs' across all paths.
     */
    match /{path=**}/qa_runs/{runId} {
      allow read: if request.auth != null;
    }
    
    match /{path=**}/bug_reports/{bugId} {
      allow read: if request.auth != null;
    }
  }
}