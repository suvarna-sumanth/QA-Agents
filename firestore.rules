rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PROTOTYPE RULES
     * Allows all authenticated users full access to all documents.
     * This is the most permissive rule for debugging and prototype development.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * Explicit rules for Collection Group queries.
     * Even with a global wildcard, some environments require explicit collection group matches.
     */
    match /{allPaths=**}/qa_runs/{runId} {
      allow read, write: if request.auth != null;
    }
    match /{allPaths=**}/articles/{articleId} {
      allow read, write: if request.auth != null;
    }
    match /{allPaths=**}/publisher_sites/{siteId} {
      allow read, write: if request.auth != null;
    }
  }
}