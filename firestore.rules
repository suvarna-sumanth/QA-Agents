rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PROTOTYPE RULES
     * Allows all authenticated users full access to all documents.
     * This includes direct paths and collection group queries.
     * Simplest possible rule to ensure no blocks for the prototype.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}