{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "./scripts/setup-db.sh",
    "dev": "npm run predev && node scripts/run-dev-with-cloudflare.js",
    "dev:next": "next dev --turbopack -p 9002",
    "supabase:stop": "cd supabase/docker && docker-compose down",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "NODE_ENV=production next build",
    "start": "next start -p 9002",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint:agno": "eslint agents/core --fix || true"
  },
